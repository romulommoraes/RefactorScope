{
  "rootPath": "C:\\Users\\romul\\source\\repos\\RefactorScope",

  "outputPath": "refactorscope-self-analysis",

  "include": [],
  "exclude": [
    "bin",
    "obj",
    ".vs",
    "refactorscope-self-analysis"
  ],

   "parser": "Selective",

  "parserOptions": {
    "enableInteractiveSelector": true,
    "enableStatistics": true,
    "logParsingBreakdown": true
  },

  "estimator": {
    "enabled": true
  },

  "analyzers": {
    "zombie": true,
    "zombieRefinement": true,
    "architecture": true,
    "coreIsolation": true,
    "entrypoints": true,
    "coupling": true,
    "solid": true,
    "statistics": true
  },

  "zombieDetection": {
    "enableRefinement": true,
    "globalRateThreshold_DI": 0.25,
    "globalRateThreshold_Interface": 0.20,
    "diProbability": 0.15,
    "interfaceProbability": 0.20,
    "minUnresolvedProbabilityThreshold": 0.30
  },

  "layerRules": {
    "UI": {
      "nameStartsWith": [ "Aba" ],
      "namespaceContains": [ "Reporting", "CLI" ]
    },

    "Core": {
      "namespaceContains": [ "Core", "Analyzers", "Model", "Nucleo" ]
    },

    "Infra": {
      "namespaceContains": [ "Infrastructure" ],
      "nameEquals": [ "Program" ]
    }
  },

  "exporters": [
    "htmlDashboard",
    "dumpAnalysis",
    "dumpIA"
  ],

  "dashboard": {
    "theme": "ember-ops"
  },

  "dumpStrategy": {
    "mode": "segmented",
    "splitBy": "topFolder"
  },

  "fitnessGates": {
    "deadCode": {
      "warnAbove": 0.05,
      "failAbove": 0.10
    },

    "coupling": {
      "warnAbove": 4,
      "failAbove": 8
    },

    "coreIsolation": {
      "failIfAny": true
    },

    "solidAlerts": {
      "warnAbove": 5,
      "failAbove": 15
    },

    "smellIndex": {
      "warnAbove": 40,
      "failAbove": 65
    }


  }
}